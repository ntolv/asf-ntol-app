function getDisplayedRoleLabel(role: unknown) {
  const value = String(role || "").trim();
  return value ? value : "Rôle backend";
}

function getWelcomeMessage(role: unknown) {
  const value = String(role || "").trim().toLowerCase();

  if (value === "admin") {
    return "Pilotez l’association, suivez les opérations clés et accédez rapidement à tous les espaces stratégiques.";
  }

  if (value === "president") {
    return "Retrouvez votre espace central de coordination pour suivre la vie associative, les membres et les décisions importantes.";
  }

  if (value === "tresorier") {
    return "Accédez à votre espace de suivi financier pour consulter les contributions, la caisse, les aides et les opérations sensibles.";
  }

  return "Retrouvez ici votre espace principal pour consulter les activités de l’association, suivre les membres et accéder rapidement à toutes les pages utiles.";
}

